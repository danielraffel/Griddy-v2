# JUCE Plugin Environment Configuration
# Copy this file to .env and adjust the values for your machine.

# Project Configuration
PROJECT_NAME=Griddy
PRODUCT_NAME="Griddy"
PROJECT_BUNDLE_ID=com.danielraffel.griddy
DEVELOPER_NAME="Generous Corp"

# JUCE Plugin Codes
PLUGIN_CODE=GRDM
PLUGIN_MANUFACTURER_CODE=Juce

# Directory Path
PROJECT_PATH="/path/to/griddy"

# Version Information
VERSION_MAJOR=1
VERSION_MINOR=0
VERSION_PATCH=64
VERSION_BUILD=65

# Apple Developer Settings
APPLE_ID=your-apple-id@example.com
TEAM_ID=YOURTEAMID
APP_CERT="Developer ID Application: Your Name (YOURTEAMID)"
INSTALLER_CERT="Developer ID Installer: Your Name (YOURTEAMID)"
APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# GitHub Settings
GITHUB_USER=your-github-user
GITHUB_REPO=Griddy

# Feature Flags
USE_VISAGE_UI=TRUE
ENABLE_DIAGNOSTICS=false

# Build Configuration
CMAKE_BUILD_TYPE=Release
BUILD_DIR=build
BUILD_FORMATS="AU VST3 Standalone"
DEFAULT_CONFIG=Release
COPY_AFTER_BUILD=TRUE

# JUCE Configuration
JUCE_REPO=https://github.com/juce-framework/JUCE.git
JUCE_TAG=8.0.12

# Platform Specific - macOS
OSX_DEPLOYMENT_TARGET=15.0
OSX_ARCHITECTURES="arm64;x86_64"

# Audio/MIDI Settings
DEFAULT_SAMPLE_RATE=48000
DEFAULT_BUFFER_SIZE=256
ENABLE_MIDI_INPUT=TRUE
ENABLE_MIDI_OUTPUT=TRUE

# Release Notes Generation
RELEASE_NOTES_METHOD=claude
OPENROUTER_KEY_PRIVATE=or-v1-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx
RELEASE_NOTES_MODEL=openai/gpt-4o-mini
